# ======================================================
# MES 系統快取控制
# 目的：確保使用者每次都能取得最新版本，不需手動清除快取
# ======================================================

# --- 入口頁優先順序：index.php 優先於 index.html ---
# index.php 會在 HTTP 層設定 no-cache，並對所有靜態資源附加版本戳記
DirectoryIndex index.php index.html

# --- HTML 入口頁：完全不快取 ---
# 保證每次訪問 index.html / login.html 都從伺服器取得最新版本
<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# --- 版本化靜態資產：入口會附加內容版本戳，可安全長期快取 ---
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|woff2?|png|jpe?g|gif|svg|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header unset Pragma
    </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Brotli 優先，未啟用時由 deflate 提供 gzip。
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# --- PHP API：完全不快取（API 回應必須即時） ---
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
