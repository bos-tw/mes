# =============================================
# MES 螺絲篩分管理系統 - Git 版本控制排除清單
# =============================================

# ⚠️ 重要：資料庫憑證設定檔 (S-1 安全修正)
# 目前團隊決議：api/config.php 允許進版控以支援多機開發。
# 若未來要回復安全模式，可改回忽略並改用環境變數注入。

# 建議：使用範本複製後加入本機設定
# cp api/config.php.example api/config.php

# ── 上傳檔案 ────────────────────────────────
uploads/logos/*.jpg
uploads/logos/*.jpeg
uploads/logos/*.png
uploads/logos/*.gif
uploads/logos/*.webp
uploads/**
!uploads/_fixtures/
!uploads/_fixtures/**
export/**
db_backups/**
db_exports/**
old/**

# ── 打包產物 ────────────────────────────────
dist/*.zip

# ── 相依套件 ────────────────────────────────
vendor/

# ── 環境設定 ────────────────────────────────
.env
.env.local
.env.production

# ── 編輯器設定 ──────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── 系統檔案 ────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 測試產出 ────────────────────────────────
tests/output/
*.log

# ── 備份檔案 ────────────────────────────────
backup/
*.bak
*.backup
