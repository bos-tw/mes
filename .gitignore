# ⚠️ 重要：資料庫憑證設定檔 (S-1 安全修正)
# 正式環境請透過環境變數注入，而非修改此檔案：
#   SCREWSYSTEM_DB_HOST
#   SCREWSYSTEM_DB_NAME
#   SCREWSYSTEM_DB_USER
#   SCREWSYSTEM_DB_PASSWORD
api/config.php

# 建議：使用範本複製後加入本機設定
# cp api/config.php.example api/config.php

